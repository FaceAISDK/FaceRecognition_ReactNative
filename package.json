{
  "name": "@faceaisdk/react-native-face-sdk",
  "version": "0.4.1",
  "description": "React Native offline face enrollment, verification, and liveness detection SDK.",
  "license": "FaceAISDK License",
  "author": "FaceAISDK.Service@gmail.com",
  "homepage": "https://github.com/FaceAISDK/FaceAISDK_RN",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FaceAISDK/FaceAISDK_RN.git"
  },
  "bugs": {
    "url": "https://github.com/FaceAISDK/FaceAISDK_RN/issues"
  },
  "source": "src/index.ts",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "react-native": "src/index.ts",
  "sideEffects": false,
  "files": [
    "src",
    "lib",
    "ios/*.{h,m,mm,swift}",
    "ios/FaceAISDK",
    "ios/Resources",
    "android/src",
    "android/libs",
    "android/build.gradle",
    "android/proguard-rules.pro",
    "scripts/faceaisdk_post_install.rb",
    "react-native-face-sdk.podspec",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf lib",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "prepare": "npm run clean && npm run build",
    "prepublishOnly": "npm run typecheck && npm run lint && npm test",
    "test": "jest --runInBand",
    "lint": "eslint src __tests__",
    "pack": "npm pack .",
    "package:build": "npm run build",
    "package:typecheck": "npm run typecheck",
    "package:pack": "npm run pack",
    "example:deps": "npm --prefix example run ensure:deps",
    "dev:bootstrap": "npm install && npm run example:deps",
    "example:bundle:ios": "npm run example:deps && cd example && node ../node_modules/react-native/cli.js bundle --platform ios --dev true --entry-file index.js --bundle-output /tmp/facern-example-ios.bundle --assets-dest /tmp/facern-example-assets --config metro.config.js --reset-cache",
    "release:verify": "npm run typecheck && npm run build && npm test && bash ./scripts/verify-example-package.sh",
    "publish:dry-run": "npm run release:verify && npm publish --dry-run --access public",
    "start": "npm --prefix example run start",
    "android": "npm --prefix example run android",
    "ios": "npm --prefix example run ios",
    "pods:install": "npm --prefix example run pods:install",
    "example:test": "npm --prefix example run test"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "face-recognition",
    "liveness-detection",
    "offline-face-sdk",
    "biometrics",
    "face-id"
  ],
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.71.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.84.0",
    "@react-native/eslint-config": "0.84.0",
    "@react-native/metro-config": "0.84.0",
    "@react-native/typescript-config": "0.84.0",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "ios-deploy": "^1.12.2",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react": "19.2.3",
    "react-native": "0.84.0",
    "react-native-safe-area-context": "^5.5.2",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
